  "keyFeatures": [
    "Tailwind CSS 4.x integration with custom theme configuration",
    "Alpine.js with plugins (collapse, focus, intersect)",
    "37 pre-built HubSpot modules (buttons, cards, testimonials, pricing, etc.)",
    "Custom HubL macros (slugify, unique-id, minutes-to-read)",
    "Multiple page templates (blog, landing page, home, pricing)",
    "HubSpot CLI integration with watch mode",
    "esbuild bundling for JavaScript",
    "Flying Pages prefetching for fast navigation",
    "Responsive design with mobile breakpoints",
    "Version management scripts"
  ],
  "publicApiSurface": [
    "slugify(text)",
    "unique_id()",
    "minutes_to_read()",
    "random_int()",
    "Alpine.data('xDOM')",
    "loadScript(url, position, callback)",
    "debugLog(...args)",
    "npm run start - Local development with watch mode",
    "npm run build - Production build",
    "npm run upload:hubspot - Upload to HubSpot",
    "npm run watch:hubspot - Watch and sync to HubSpot",
    "npm run version:patch|minor|major - Bump theme version"
  ]
}
